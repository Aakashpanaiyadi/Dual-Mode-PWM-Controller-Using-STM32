#include<stm32f10x.h>
#define remote (GPIOA->IDR & (1<<2))
void delay(unsigned int x)
{
while(x--);
}
void pwmgen();
void adcinit();
void usartinit();
int adcvalue();
volatile int convertvalue=0;
void adcinit(void)
{
	ADC1->CR2 |= (1<<0);  // ADCON `
	delay(1000);
	ADC1->CR2|= (1<<3);  // RESET CALBIRATION
	while(ADC1->CR2 &(1<<3)); // WAIT UNTILL HARDWARE RESET
	ADC1 ->CR2 |= (1<<2); // CAL ENABLE
	while(ADC1->CR2&(1<<2)); // WAIT UNTILL HARDWARE RESET
	ADC1->SMPR2 &= ~(0X7<<3); 
	ADC1->SMPR2 |= (0X5<<3); // SELECT SAMPLE TIME
	ADC1->SQR3=1; // CHANNEL 1
	ADC1->CR2 |= (1<<20);   // EXTTRIG
  ADC1->CR2 |= (7<<17);   // SWSTART selected as trigger
}
void usartinit()
{
	USART1->CR1 |= (1<<2);   // RX
	USART1->CR1 |= (1<<3);  // TX
	USART1->CR1 |= (1<<13); // USART ENABLE
	USART1->BRR =0X1D4C;   // BAUDRATE
}
int adcvalue()
{
	ADC1->CR2 |= (1<<22);        // SWSTART
	while(!(ADC1->SR &(1<<1)));    // Wait EOC
  convertvalue = (ADC1->DR*100)/4095; //0-100%
	return convertvalue;
}
void pwmgen()
{
	TIM2->PSC=71; // PRESCALAR  EVERY 1us COUNTER INC
	TIM2->ARR=50; // 50us TIME PERIOD
	TIM2->CCR1=0; // INTAIL ZERO DUTY CYCLE
	TIM2->CR1 |= (1<<7); // ARP ENABLE
	TIM2->CCMR1 |= (1<<3); // PRE LOAD ENABLE
	TIM2 ->CCMR1 |= (6<<4);/// PWM MODE 1
	TIM2->CCER |= (1<<0); // COMPARE CAPTURE ENABLE
	TIM2->EGR |= (1<<0);  // ENABLE UG BIT
	TIM2->CR1 |= (1<<0);  // ENABLE COUNTER
}
int main()
{
	// CLOCK CONFIG
	
	RCC->APB2ENR |= (1<<9); //ADC1
	RCC->APB2ENR |= (1<<14); // UART1
	RCC->APB1ENR |= (1<<21);  //I2C1
	RCC->APB1ENR |= (1<<0);   //TIM2
	RCC->CFGR|=(0X2<<14); // PRESCAL ADC
	RCC->APB2ENR |= (1<<2);  
	RCC->APB2ENR |= (1<<3); // ENABLE A AND B PORT
	RCC->APB2ENR |= (1 << 0); // AF CLK ENABLE
	
	// PORT CNFG
	GPIOA->CRL &= ~(0XFFF<<0);  // RESET THE A0 & A1 ,A2 REMOTE
	GPIOA->CRL |= (0x0B << 0);  // PA0 PWM
	GPIOA->CRL |= (0x00 << 4);    // PA1 AS ANALOG
	GPIOA->CRL |= (0x08 << 8);  // A2 SET INPUT
	GPIOA->CRH &= ~(0XFF<<4);  // RESET THE A9 & A10 FOR RX TX
	GPIOA->CRH |= (0XB<<4);   // AS  A9 TX
	GPIOA->CRH |= (0X4<<8);   // AS A10 RX
	//GPIOB->CRL &= ~(0XFF<<24);  // RESET THE B6 & B7 FOR SCL SDA
	//GPIOB->CRL |= (0XFF<<24);  //  AS SCL SDA
	GPIOA->ODR &= ~(1<<2); //  A2 PULLDOWN
	adcinit();
	pwmgen();
	usartinit();
	while(1)
	{
	
		if(remote)
		{
			while(!(USART1->SR & (1<<5))); // wait
			TIM2->CCR1=USART1->DR;    // extarnal controller duty cycle
		}
		else
		{
		TIM2->CCR1=(adcvalue()*50) / 100;
		}
	}
}
	
